# ═══════════════════════════════════════════════════════════════════════════════
# AI 업무도우미 .gitignore
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# 환경 설정 & 시크릿 (절대 커밋 금지)
# ─────────────────────────────────────────────────────────────────────────────
.env
!.env.example

# ─────────────────────────────────────────────────────────────────────────────
# oh-my-claudecode / Claude / Playwright MCP
# ─────────────────────────────────────────────────────────────────────────────
.omc/**
!.omc/
!.omc/plans/
!.omc/plans/**
.claude/
.playwright-mcp/

# ─────────────────────────────────────────────────────────────────────────────
# 운영 임시 자료 (스크린샷·로그·노트 등)
# ─────────────────────────────────────────────────────────────────────────────
_참고자료/

# ─────────────────────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/
.venv/
venv/
env/

# ─────────────────────────────────────────────────────────────────────────────
# Backend 데이터 (런타임 생성)
# ─────────────────────────────────────────────────────────────────────────────
*.db
backend/data/**
!backend/data/
!backend/data/knowledge/
!backend/data/knowledge/_schema.yaml
backend/models/
backend/server.log
backend/server-*.log
backend/backend-*.log
/models/

# ─────────────────────────────────────────────────────────────────────────────
# Graphify 산출물 (재생성 가능)
# ─────────────────────────────────────────────────────────────────────────────
graphify-out/

# ─────────────────────────────────────────────────────────────────────────────
# 백업 파일 generic (backup-{ts}, .bak 등)
# ─────────────────────────────────────────────────────────────────────────────
*.backup-*
*.bak
*.orig

# ─────────────────────────────────────────────────────────────────────────────
# OneDrive / Office 임시 파일
# ─────────────────────────────────────────────────────────────────────────────
~$*
.~lock.*

# ─────────────────────────────────────────────────────────────────────────────
# Frontend
# ─────────────────────────────────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/dist-ssr/
*.local

# ─────────────────────────────────────────────────────────────────────────────
# 로그
# ─────────────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ─────────────────────────────────────────────────────────────────────────────
# IDE / 에디터
# ─────────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db

# ─────────────────────────────────────────────────────────────────────────────
# Persona Tests / E2E (생성되는 결과물)
# ─────────────────────────────────────────────────────────────────────────────
personas/output/
personas/node_modules/
personas/test-results/
e2e/test-results/
e2e/playwright-report/
playwright-report/
test-results/

# ─────────────────────────────────────────────────────────────────────────────
# 테스트·캐시
# ─────────────────────────────────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
*.tsbuildinfo
.vite/
frontend/.vite/

# ─────────────────────────────────────────────────────────────────────────────
# OS
# ─────────────────────────────────────────────────────────────────────────────
desktop.ini
ehthumbs.db

# ─────────────────────────────────────────────────────────────────────────────
# Root-level Playwright (personas/ 폴더에서 별도 관리)
# ─────────────────────────────────────────────────────────────────────────────
/package.json
/package-lock.json
/playwright.config.ts

# ─────────────────────────────────────────────────────────────────────────────
# Custom
# ─────────────────────────────────────────────────────────────────────────────
data/*
tests/*
test-results/*
exception/*