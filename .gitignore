# ═══════════════════════════════════════════════════════════════════════════════
# AI 업무도우미 .gitignore
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# 환경 설정 & 시크릿 (절대 커밋 금지)
# ─────────────────────────────────────────────────────────────────────────────
.env
!.env.example

# ─────────────────────────────────────────────────────────────────────────────
# oh-my-claudecode / Claude / Playwright MCP
# ─────────────────────────────────────────────────────────────────────────────
.omc/
.claude/
.playwright-mcp/

# ─────────────────────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/
.venv/
venv/
env/

# ─────────────────────────────────────────────────────────────────────────────
# Backend 데이터 (런타임 생성)
# ─────────────────────────────────────────────────────────────────────────────
*.db
backend/data/
backend/models/
backend/server.log
models/

# ─────────────────────────────────────────────────────────────────────────────
# Frontend
# ─────────────────────────────────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/dist-ssr/
*.local

# ─────────────────────────────────────────────────────────────────────────────
# 로그
# ─────────────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ─────────────────────────────────────────────────────────────────────────────
# IDE / 에디터
# ─────────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db

# ─────────────────────────────────────────────────────────────────────────────
# OS
# ─────────────────────────────────────────────────────────────────────────────
desktop.ini
ehthumbs.db
