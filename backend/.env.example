# AI 업무도우미 Backend 환경 설정
# 이 파일을 .env로 복사하고 실제 값을 입력하세요

# 기본 설정
DEBUG=true
APP_NAME="AI 업무도우미 API"

# 데이터베이스
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# Redis (Celery 사용시)
REDIS_URL=redis://localhost:6379/0

# ═══════════════════════════════════════════════════════════════════════════════
# 벡터 DB & 임베딩 설정 (완전 오프라인, 로컬 모델 사용)
# ═══════════════════════════════════════════════════════════════════════════════
CHROMA_PERSIST_DIR=./data/chroma

# 로컬 임베딩 모델 (ONNX Runtime + tokenizers, 완전 오프라인)
# model.onnx가 없으면 pytorch_model.bin에서 자동 변환 (최초 1회)
ONNX_MODEL_PATH=./models/onnx/jhgan_ko-sroberta-multitask
MODEL_CACHE_DIR=./models

# ═══════════════════════════════════════════════════════════════════════════════
# LLM 설정
# ═══════════════════════════════════════════════════════════════════════════════

# 기본 LLM 설정 (openai | azure | anthropic | custom_api)
DEFAULT_LLM_PROVIDER=openai
DEFAULT_MODEL=gpt-4o-mini

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here

# Azure OpenAI Service
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-azure-api-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# ═══════════════════════════════════════════════════════════════════════════════
# 타 시스템 API 설정 (Custom API)
# DEFAULT_LLM_PROVIDER=custom_api 로 설정시 아래 값들이 사용됩니다
# ═══════════════════════════════════════════════════════════════════════════════
CUSTOM_API_URL=https://your-system.com/api/llm/chat
CUSTOM_API_KEY=your-custom-api-key-here
CUSTOM_API_MODEL=default
CUSTOM_API_TIMEOUT=60

# ═══════════════════════════════════════════════════════════════════════════════
# 외부 LLM 우회 시스템 설정 (External LLM - Dify/Agent Builder 호환)
# EXTERNAL_LLM=true 설정시 모든 LLM 호출이 우회 시스템으로 라우팅됩니다
# Dify/Agent Builder 스타일 API (POST /v1/chat-messages, blocking 모드)
# ═══════════════════════════════════════════════════════════════════════════════
# EXTERNAL_LLM=true
# EXTERNAL_LLM_API_KEY=your-external-api-key-here
# EXTERNAL_LLM_API_URL=https://api.example.com/v1/chat-messages

# 샌드박스 설정
SANDBOX_TIMEOUT_SECONDS=10
SANDBOX_MAX_OUTPUT_SIZE=1048576

# CORS (프론트엔드 URL)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
